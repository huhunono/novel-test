# =============================================================================
# novel-api-tests — Environment Configuration Example
# =============================================================================
# Copy this file to .env and fill in the values for your local environment.
#
#   cp .env.example .env
#
# .env is git-ignored and will never be committed.
# In CI (GitHub Actions), these are set as repository Secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# API Backend
# -----------------------------------------------------------------------------
# Base URL of the backend under test.
# Local default: http://127.0.0.1:8083
# Docker Compose (local): port mapping is 8083 -> container 8085
BASE_URL=http://127.0.0.1:8083

# -----------------------------------------------------------------------------
# Test User Credentials
# -----------------------------------------------------------------------------
# Must exist in the backend database before running authenticated tests.
# See scripts/init.sql for the seed SQL to create this user.
TEST_USERNAME=13560421999
TEST_PASSWORD=123456

# -----------------------------------------------------------------------------
# Database Connection
# -----------------------------------------------------------------------------
# Used by DB-validation fixtures (conftest.py db_conn).
# Local default: connects to Docker MySQL via host-mapped port.
#
# Local Docker port mapping: 3307 (host) -> 3306 (container)
# CI Docker port mapping:    3307 (host) -> 3306 (container)
DB_HOST=127.0.0.1
DB_PORT=3307
DB_USER=root
DB_PASSWORD=test123456
DB_NAME=novel_plus
